{
  "UseDatabase": false,

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PersonalFinanceDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "PersonalFinanceAPI",
    "Audience": "PersonalFinanceClients",
    "ExpirationMinutes": 60
  },

  "ExchangeRateApi": {
    "BaseUrl": "https://v6.exchangerate-api.com/v6",
    "ApiKey": "YOUR_EXCHANGERATE_API_KEY_HERE",
    "CacheDurationMinutes": 60
  },

  "Cors": {
    "PolicyName": "PersonalFinancePolicy",
    "AllowedOrigins": []
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
